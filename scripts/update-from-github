#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/song-request-linux"
LOG_DIR="$STATE_DIR/logs"
LOG_FILE="$LOG_DIR/update.log"
STATUS_FILE="$STATE_DIR/update-status.json"
START_AFTER=0
STOP_BEFORE=1
before_rev=""
after_rev=""

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

write_status() {
  local status="$1"
  local message="$2"
  local before="${3:-$before_rev}"
  local after="${4:-$after_rev}"
  local timestamp
  timestamp="$(date -Is)"
  mkdir -p "$STATE_DIR"
  printf '{"status":"%s","message":"%s","before":"%s","after":"%s","timestamp":"%s"}\n' \
    "$(json_escape "$status")" \
    "$(json_escape "$message")" \
    "$(json_escape "$before")" \
    "$(json_escape "$after")" \
    "$(json_escape "$timestamp")" >"$STATUS_FILE"
}

on_error() {
  local exit_code=$?
  write_status "failed" "Atualizacao falhou. Abra os logs em ~/.local/state/song-request-linux/logs/update.log."
  exit "$exit_code"
}
trap on_error ERR

for arg in "$@"; do
  case "$arg" in
    --restart|--start) START_AFTER=1 ;;
    --no-stop) STOP_BEFORE=0 ;;
    -h|--help)
      cat <<HELP
Usage: ./scripts/update-from-github [--restart] [--no-stop]

Atualiza o Song Request Linux a partir do GitHub remoto configurado no repo.
Config, tokens, logs e fila ficam preservados nos caminhos XDG do usuario.
Use --no-stop apenas para teste/CI quando outro app local estiver rodando na porta 7384.
HELP
      exit 0
      ;;
    *) echo "Opcao desconhecida: $arg" >&2; exit 2 ;;
  esac
done

mkdir -p "$LOG_DIR"
write_status "running" "Atualizacao em andamento. O app pode reiniciar em alguns segundos."

{
  echo "== Song Request Linux Update =="
  date -Is
  echo "Projeto: $APP_DIR"
} >>"$LOG_FILE"

if ! command -v git >/dev/null 2>&1; then
  echo "ERRO: git nao encontrado." | tee -a "$LOG_FILE" >&2
  exit 1
fi

if ! command -v cargo >/dev/null 2>&1; then
  echo "ERRO: cargo nao encontrado." | tee -a "$LOG_FILE" >&2
  exit 1
fi

cd "$APP_DIR"

before_rev="$(git rev-parse --short HEAD 2>/dev/null || true)"
after_rev="$before_rev"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ERRO: este diretorio nao e um repo git." | tee -a "$LOG_FILE" >&2
  exit 1
fi

if [[ -n "$(git status --porcelain --untracked-files=no)" ]]; then
  echo "ERRO: existem alteracoes locais em arquivos rastreados. Salve ou descarte antes de atualizar." | tee -a "$LOG_FILE" >&2
  git status --short --untracked-files=no | tee -a "$LOG_FILE" >&2
  exit 1
fi

if (( STOP_BEFORE )); then
  ./scripts/song-request-linux-stop >>"$LOG_FILE" 2>&1 || true
fi

git fetch --prune >>"$LOG_FILE" 2>&1

branch="$(git branch --show-current)"
if [[ -z "$branch" ]]; then
  echo "ERRO: repo esta em detached HEAD. Atualize manualmente." | tee -a "$LOG_FILE" >&2
  exit 1
fi

upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null || true)"
if [[ -n "$upstream" ]]; then
  git pull --ff-only >>"$LOG_FILE" 2>&1
else
  git pull --ff-only origin "$branch" >>"$LOG_FILE" 2>&1
fi

after_rev="$(git rev-parse --short HEAD)"

cargo build --release >>"$LOG_FILE" 2>&1
./scripts/install-desktop-entry >>"$LOG_FILE" 2>&1

if (( START_AFTER )); then
  ./scripts/song-request-linux-open >>"$LOG_FILE" 2>&1 &
fi

if [[ -n "$before_rev" && "$before_rev" != "$after_rev" ]]; then
  message="Atualizado com sucesso: baixou $before_rev -> $after_rev."
  status="updated"
else
  message="Ja estava atualizado. Commit atual: $after_rev."
  status="up_to_date"
fi

write_status "$status" "$message" "$before_rev" "$after_rev"
echo "$message" | tee -a "$LOG_FILE"
