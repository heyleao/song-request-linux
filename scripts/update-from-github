#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/song-request-linux"
DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
INSTALL_ROOT="$DATA_HOME/song-request-linux"
PORTABLE_APP_DIR="$INSTALL_ROOT/app"
LOG_DIR="$STATE_DIR/logs"
LOG_FILE="$LOG_DIR/update.log"
STATUS_FILE="$STATE_DIR/update-status.json"
START_AFTER=0
STOP_BEFORE=1
before_rev=""
after_rev=""

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

write_status() {
  local status="$1"
  local message="$2"
  local before="${3:-$before_rev}"
  local after="${4:-$after_rev}"
  local timestamp
  timestamp="$(date -Is)"
  mkdir -p "$STATE_DIR"
  printf '{"status":"%s","message":"%s","before":"%s","after":"%s","timestamp":"%s"}\n' \
    "$(json_escape "$status")" \
    "$(json_escape "$message")" \
    "$(json_escape "$before")" \
    "$(json_escape "$after")" \
    "$(json_escape "$timestamp")" >"$STATUS_FILE"
}

on_error() {
  local exit_code=$?
  write_status "failed" "Atualizacao falhou. Abra os logs em ~/.local/state/song-request-linux/logs/update.log."
  exit "$exit_code"
}
trap on_error ERR

for arg in "$@"; do
  case "$arg" in
    --restart|--start) START_AFTER=1 ;;
    --no-stop) STOP_BEFORE=0 ;;
    -h|--help)
      cat <<HELP
Usage: ./scripts/update-from-github [--restart] [--no-stop]

Atualiza o Song Request Linux.
- Em repositorio Git: usa git pull + cargo build.
- Em pacote portatil: baixa o tar.gz mais recente da release e reinstala em ~/.local/share/song-request-linux/app.
HELP
      exit 0
      ;;
    *) echo "Opcao desconhecida: $arg" >&2; exit 2 ;;
  esac
done

mkdir -p "$LOG_DIR"
: >"$LOG_FILE"
write_status "running" "Atualizacao em andamento. O app pode reiniciar em alguns segundos."

{
  echo "== Song Request Linux Update =="
  echo "Data: $(date -Is)"
} >>"$LOG_FILE"

update_git_repo() {
  if ! command -v git >/dev/null 2>&1; then
    echo "ERRO: git nao encontrado." | tee -a "$LOG_FILE" >&2
    exit 1
  fi

  if ! command -v cargo >/dev/null 2>&1; then
    echo "ERRO: cargo nao encontrado." | tee -a "$LOG_FILE" >&2
    exit 1
  fi

  cd "$APP_DIR"
  before_rev="$(git rev-parse --short HEAD 2>/dev/null || true)"
  after_rev="$before_rev"

  if [[ -n "$(git status --porcelain --untracked-files=no)" ]]; then
    echo "ERRO: existem alteracoes locais em arquivos rastreados. Salve ou descarte antes de atualizar." | tee -a "$LOG_FILE" >&2
    git status --short --untracked-files=no | tee -a "$LOG_FILE" >&2
    exit 1
  fi

  if (( STOP_BEFORE )); then
    ./scripts/song-request-linux-stop >/dev/null 2>&1 || true
  fi

  echo "Modo: repositorio Git" >>"$LOG_FILE"
  git fetch --prune >/dev/null 2>&1
  branch="$(git branch --show-current)"
  if [[ -z "$branch" ]]; then
    echo "ERRO: repo esta em detached HEAD. Atualize manualmente." | tee -a "$LOG_FILE" >&2
    exit 1
  fi

  upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null || true)"
  if [[ -n "$upstream" ]]; then
    git pull --ff-only >/dev/null 2>&1
  else
    git pull --ff-only origin "$branch" >/dev/null 2>&1
  fi
  echo "Download: OK" >>"$LOG_FILE"

  after_rev="$(git rev-parse --short HEAD)"
  cargo build --release >/dev/null 2>&1
  echo "Build: OK" >>"$LOG_FILE"
  ./scripts/install-desktop-entry >/dev/null 2>&1
  echo "Instalacao: OK" >>"$LOG_FILE"

  if (( START_AFTER )); then
    (cd "$HOME" && "$APP_DIR/scripts/song-request-linux-open" >/dev/null 2>&1 &)
  fi

  if [[ -n "$before_rev" && "$before_rev" != "$after_rev" ]]; then
    echo "Resultado: atualizado com sucesso $before_rev -> $after_rev" >>"$LOG_FILE"
    write_status "updated" "Atualizado com sucesso: baixou $before_rev -> $after_rev." "$before_rev" "$after_rev"
  else
    echo "Resultado: ja estava atualizado ($after_rev)" >>"$LOG_FILE"
    write_status "up_to_date" "Ja estava atualizado. Commit atual: $after_rev." "$before_rev" "$after_rev"
  fi
}

update_portable_release() {
  if ! command -v curl >/dev/null 2>&1; then
    echo "ERRO: curl nao encontrado." | tee -a "$LOG_FILE" >&2
    exit 1
  fi
  if ! command -v tar >/dev/null 2>&1; then
    echo "ERRO: tar nao encontrado." | tee -a "$LOG_FILE" >&2
    exit 1
  fi
  if ! command -v sha256sum >/dev/null 2>&1; then
    echo "ERRO: sha256sum nao encontrado." | tee -a "$LOG_FILE" >&2
    exit 1
  fi

  local arch package_arch api tag url tmp archive checksum_file archive_name new_dir entry
  arch="$(uname -m)"
  case "$arch" in
    x86_64|amd64) package_arch="x86_64" ;;
    aarch64|arm64) package_arch="aarch64" ;;
    *) package_arch="$arch" ;;
  esac

  before_rev="$(basename "$APP_DIR")"
  api="$(curl -fsSL https://api.github.com/repos/heyleao/song-request-linux/releases/latest)"
  tag="$(printf '%s\n' "$api" | sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p' | head -1)"
  url="$(printf '%s\n' "$api" | sed -n "s/.*\"browser_download_url\": *\"\\([^\"]*song-request-linux-[^\"]*-linux-${package_arch}\\.tar\\.gz\\)\".*/\\1/p" | head -1)"

  if [[ -z "$tag" || -z "$url" ]]; then
    echo "ERRO: nao encontrei pacote Linux $package_arch na ultima release." | tee -a "$LOG_FILE" >&2
    exit 1
  fi

  after_rev="$tag"
  tmp="$(mktemp -d "${TMPDIR:-/tmp}/song-request-linux-update.XXXXXX")"
  archive_name="$(basename "$url")"
  archive="$tmp/$archive_name"
  checksum_file="$archive.sha256"
  echo "Modo: instalacao local" >>"$LOG_FILE"
  echo "Release: $tag" >>"$LOG_FILE"
  curl -fsSL "$url" -o "$archive" >/dev/null 2>&1
  echo "Download: OK" >>"$LOG_FILE"

  curl -fsSL "${url}.sha256" -o "$checksum_file" >/dev/null 2>&1
  (
    cd "$tmp"
    sha256sum -c "$(basename "$checksum_file")" >/dev/null
  )
  echo "Checksum: OK" >>"$LOG_FILE"

  while IFS= read -r entry; do
    case "$entry" in
      song-request-linux-*-linux-*/*) ;;
      *)
        echo "ERRO: pacote contem caminho inesperado: $entry" | tee -a "$LOG_FILE" >&2
        exit 1
        ;;
    esac
  done < <(tar -tzf "$archive")

  tar -xzf "$archive" -C "$tmp" >/dev/null 2>&1
  echo "Extracao: OK" >>"$LOG_FILE"
  new_dir="$(find "$tmp" -maxdepth 1 -type d -name 'song-request-linux-*-linux-*' | head -1)"
  if [[ -z "$new_dir" || ! -x "$new_dir/scripts/install-desktop-entry" ]]; then
    echo "ERRO: pacote baixado nao contem instalador valido." | tee -a "$LOG_FILE" >&2
    exit 1
  fi

  cd "$HOME"

  if (( STOP_BEFORE )); then
    "$APP_DIR/scripts/song-request-linux-stop" >/dev/null 2>&1 || true
  fi

  "$new_dir/scripts/install-desktop-entry" >/dev/null 2>&1
  echo "Instalacao: OK" >>"$LOG_FILE"

  if (( START_AFTER )); then
    (cd "$HOME" && "$PORTABLE_APP_DIR/scripts/song-request-linux-open" >/dev/null 2>&1 &)
  fi

  echo "Resultado: atualizado com sucesso para $tag" >>"$LOG_FILE"
  write_status "updated" "Atualizado com sucesso para $tag." "$before_rev" "$after_rev"
}

if [[ -d "$APP_DIR/.git" ]]; then
  update_git_repo
else
  update_portable_release
fi
