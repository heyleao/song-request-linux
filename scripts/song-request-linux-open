#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PID_FILE="${XDG_RUNTIME_DIR:-/tmp}/song-request-linux.pid"
LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/song-request-linux/logs"
LOG_FILE="$LOG_DIR/launcher.log"
URL="http://127.0.0.1:7384/"

mkdir -p "$LOG_DIR"

is_running() {
  [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

if is_running; then
  xdg-open "$URL" >/dev/null 2>&1 || true
  exit 0
fi

if ss -ltn 'sport = :7384' | grep -q ':7384'; then
  xdg-open "$URL" >/dev/null 2>&1 || true
  exit 0
fi

cd "$APP_DIR"

BIN=""
if [[ -x "$APP_DIR/bin/song-request-linux" ]]; then
  BIN="$APP_DIR/bin/song-request-linux"
elif [[ -x "$APP_DIR/target/release/song-request-linux" ]]; then
  BIN="$APP_DIR/target/release/song-request-linux"
elif command -v cargo >/dev/null 2>&1; then
  cargo build --release >>"$LOG_FILE" 2>&1
  TARGET_DIR="$(cargo metadata --no-deps --format-version=1 | sed -n 's/.*"target_directory":"\([^"]*\)".*/\1/p')"
  BIN="$TARGET_DIR/release/song-request-linux"
else
  echo "Song Request Linux nao encontrou binario local e cargo nao esta instalado." >&2
  echo "Reinstale pelo pacote oficial ou pelo repositorio Git." >&2
  exit 1
fi

setsid "$BIN" >>"$LOG_FILE" 2>&1 < /dev/null &
echo "$!" >"$PID_FILE"

for _ in {1..50}; do
  if curl -fsS "http://127.0.0.1:7384/health" >/dev/null 2>&1; then
    xdg-open "$URL" >/dev/null 2>&1 || true
    exit 0
  fi
  sleep 0.1
done

echo "Song Request Linux iniciou, mas o health check nao respondeu. Veja $LOG_FILE" >&2
exit 1
