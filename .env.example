# Public development defaults only.
# Do not put real tokens, client secrets, or API keys in this file.

SONG_REQUEST_BIND=127.0.0.1:7384
SONG_REQUEST_LOG=info
SONG_REQUEST_PROVIDER=youtube

# Development-only Twitch bot settings.
# Use an OAuth token for the bot account, never the streamer password.
# Keep the real token in your shell/keyring, not in this file.
TWITCH_BOT_USERNAME=
TWITCH_BOT_OAUTH_TOKEN=
TWITCH_CHANNEL=
